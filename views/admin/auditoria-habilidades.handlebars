<h2 class="titulo-secao" style="text-align: center; margin-bottom: 2rem;">AUDITORIA DE HABILIDADES</h2>

{{#if erro}}
<div style="background: #e74c3c; color: #fff; padding: 0.5rem; margin-bottom: 1rem; font-family: monospace; text-align: center;">
    [ ERRO ]: {{erro}}
</div>
{{/if}}

{{#if sucesso}}
<div style="background: #2ecc71; color: #000; padding: 0.5rem; margin-bottom: 1rem; font-family: monospace; text-align: center; font-weight: bold;">
    [ SUCESSO ]: {{sucesso}}
</div>
{{/if}}

{{#if habilidades}}
<div class="grid-estranho" style="grid-template-columns: 1fr;">
    {{#each habilidades}}
    <div class="card-receita" style="border-color: #9b59b6;">
        <h3 style="color: #9b59b6; margin-bottom: 0.8rem; font-family: monospace;">{{this.nome}}</h3>

        {{#if this.alunos.length}}
        <div style="display: flex; flex-direction: column; gap: 0.6rem;">
            {{#each this.alunos}}
            <div style="display: flex; justify-content: space-between; align-items: center; background: #111; padding: 0.6rem; border: 1px solid #222; font-family: monospace;">
                <div style="display: flex; flex-direction: column;">
                    <span style="color: #fff;">{{this.nome}}</span>
                    <span style="color: #777; font-size: 0.8rem;">{{this.email}}</span>
                </div>
                <form action="/admin/aluno-habilidade/atualizar" method="POST" style="display: flex; gap: 0.4rem; align-items: center; margin: 0;">
                    <input type="hidden" name="aluno_id" value="{{this.id}}">
                    <input type="hidden" name="habilidade_id" value="{{../id}}">
                    <input type="number" name="novo_nivel" min="0" max="10" value="{{this.nivel}}" required
                        style="width: 70px; background: #000; color: #fff; border: 1px solid #444; padding: 0.3rem; font-family: monospace; text-align: center;">
                    <button type="submit" class="btn-link" style="border-color: #2ecc71; color: #2ecc71; margin-top: 0; padding: 0.2rem 0.6rem; font-size: 0.75rem;">
                        SALVAR
                    </button>
                </form>
            </div>
            {{/each}}
        </div>
        {{else}}
        <p style="color: #777; font-style: italic;">Nenhum aluno associado a esta habilidade.</p>
        {{/if}}
    </div>
    {{/each}}
</div>
{{else}}
<p style="text-align: center; color: #e74c3c; font-family: monospace;">Nenhuma habilidade cadastrada.</p>
{{/if}}

<div style="text-align: center; margin-top: 2rem;">
    <a href="/admin" class="btn-link" style="border-color: #777; color: #777;">[ VOLTAR AO PAINEL ]</a>
</div>
