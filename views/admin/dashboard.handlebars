<h2 class="titulo-secao">👑 CENTRAL DE CONTROLE DO ADMINISTRADOR</h2>

<div class="filtros" style="margin-bottom: 2rem; border-left: 3px solid #e74c3c; padding-left: 1rem;">
    <p style="color: #e74c3c; font-family: monospace;">[ PRIVILÉGIOS ]: ROOT / ADMINISTRADOR GERAL</p>
    <p style="color: #aaa; font-size: 0.9rem;">Você tem permissão total para cadastrar, listar, editar e excluir registros.</p>
</div>

{{#if erro}}
<div style="background: #e74c3c; color: #fff; padding: 0.5rem; margin-bottom: 1rem; font-family: monospace;">
    [ ERRO ]: {{erro}}
</div>
{{/if}}

{{#if sucesso}}
<div style="background: #2ecc71; color: #000; padding: 0.5rem; margin-bottom: 1rem; font-family: monospace; font-weight: bold;">
    [ SUCESSO ]: Operação realizada com sucesso!
</div>
{{/if}}

<div class="grid-estranho" style="grid-template-columns: 1fr 2fr; align-items: start;">
    
    <div class="card-receita" style="border-color: #2ecc71;">
        <h3 style="color: #2ecc71; margin-bottom: 1rem;">👨‍🍳 Novo Aluno</h3>
        
        <form action="/admin/cadastrar" method="POST">
            <div style="margin-bottom: 1.2rem;">
                <label style="color: #aaa; display: block; margin-bottom: 0.3rem; font-size: 0.8rem;">NOME COMPLETO *</label>
                <input type="text" name="nome" required placeholder="Ex: Cobaia da Silva"
                    style="width: 100%; background: #000; color: #fff; border: 1px solid #444; padding: 0.6rem; font-family: monospace;">
            </div>

            <div style="margin-bottom: 1.2rem;">
                <label style="color: #aaa; display: block; margin-bottom: 0.3rem; font-size: 0.8rem;">E-MAIL (CREDENCIAL) *</label>
                <input type="email" name="email" required placeholder="aluno@domain.com"
                    style="width: 100%; background: #000; color: #fff; border: 1px solid #444; padding: 0.6rem; font-family: monospace;">
            </div>

            <div style="margin-bottom: 1.5rem;">
                <label style="color: #aaa; display: block; margin-bottom: 0.3rem; font-size: 0.8rem;">SENHA DE ACESSO *</label>
                <input type="password" name="senha" required placeholder="••••••••"
                    style="width: 100%; background: #000; color: #fff; border: 1px solid #444; padding: 0.6rem; font-family: monospace;">
            </div>

            <button type="submit" class="btn-link" style="width: 100%; border-color: #2ecc71; color: #2ecc71;">
                [ INJETAR ALUNO ]
            </button>
        </form>
    </div>

    <div class="card-receita" style="border-color: #e74c3c;">
        <h3 style="color: #e74c3c; margin-bottom: 1rem;">📋 Alunos Registrados no Banco</h3>
        
        {{#if alunos}}
            <div style="display: flex; flex-direction: column; gap: 1rem;">
                {{#each alunos}}
                <div style="background: #111; border: 1px solid #333; padding: 1rem; display: flex; flex-direction: column; gap: 0.5rem;">
                    
                    <form action="/admin/editar/{{this.id}}" method="POST" style="display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center;">
                        <input type="text" name="nome" value="{{this.nome}}" required 
                            style="background: #000; color: #fff; border: 1px solid #555; padding: 0.4rem; flex: 1; min-width: 150px; font-family: monospace;">
                        
                        <input type="email" name="email" value="{{this.email}}" required 
                            style="background: #000; color: #2ecc71; border: 1px solid #555; padding: 0.4rem; flex: 1; min-width: 150px; font-family: monospace;">
                        
                        <button type="submit" style="background: #2ecc71; color: #000; border: none; padding: 0.4rem 0.8rem; font-weight: bold; cursor: pointer; font-family: monospace;">
                            SALVAR
                        </button>
                    </form>

                    <form action="/admin/excluir/{{this.id}}" method="POST" style="align-self: flex-end;">
                        <button type="submit" onclick="return confirm('ATENÇÃO: Apagar este aluno destruirá as relações dele com as receitas. Confirmar?')"
                            style="background: transparent; color: #e74c3c; border: 1px solid #e74c3c; padding: 0.2rem 0.5rem; font-size: 0.8rem; cursor: pointer; font-family: monospace;">
                            [ EXCLUIR CONTA ]
                        </button>
                    </form>

                </div>
                {{/each}}
            </div>
        {{else}}
            <p style="color: #777; font-style: italic;">Nenhum aluno comum localizado no SQLite.</p>
        {{/if}}
    </div>

</div>

<div style="margin-top: 3rem; border-top: 1px dashed #444; padding-top: 2rem;">
    <h3 style="color: #9b59b6; margin-bottom: 1rem; text-align: center;">🛠️ Gerenciar Outras Entidades</h3>
    <div style="display: flex; gap: 1rem; justify-content: center;">
        <a href="/categorias" class="btn-link" style="border-color: #9b59b6; color: #9b59b6;">[ GESTÃO DE CATEGORIAS ]</a>
        <a href="/habilidades" class="btn-link" style="border-color: #3498db; color: #3498db;">[ GESTÃO DE HABILIDADES ]</a>
        <a href="/admin/auditoria-habilidades" class="btn-link" style="border-color: #2ecc71; color: #2ecc71;">[ AUDITORIA DE HABILIDADES ]</a>
        <a href="/auth/logout" class="btn-link" style="border-color: #777; color: #777;">[ SAIR / LOGOUT ]</a>
    </div>
</div>