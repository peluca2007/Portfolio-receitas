{{#if erro}}
<div style="background: #e74c3c; color: #fff; padding: 0.8rem; text-align: center; font-family: monospace; margin-bottom: 1.5rem; font-weight: bold; border: 1px solid #ff6b6b;">
    [ ALERTA ]: {{erro}}
</div>
{{/if}}

<div class="card-receita" style="max-width: 700px; margin: 2rem auto; border-color: #2ecc71; padding: 2rem; background: #0a0a0a;">
    <h2 style="color: #2ecc71; font-family: monospace; text-align: center; margin-bottom: 1.5rem; border-bottom: 1px solid #222; padding-bottom: 1rem;">
        🧪 INJETAR NOVO PROTOCOLO CULINÁRIO
    </h2>

    <form action="/receitas/nova" method="POST">

        <div style="margin-bottom: 1.5rem;">
            <label style="color: #2ecc71; display: block; margin-bottom: 0.5rem; font-family: monospace; font-weight: bold;">
                NOME DO PRATO (Máximo 50 caracteres) *
            </label>
            <input type="text" name="nome" required maxlength="50" placeholder="Ex: Chou Tofu da Dinastia Qing"
                style="width: 100%; background: #000; color: #fff; border: 1px solid #333; padding: 0.8rem; font-family: monospace; font-size: 1rem;">
        </div>

        <div style="margin-bottom: 1.5rem;">
            <label style="color: #2ecc71; display: block; margin-bottom: 0.4rem; font-family: monospace; font-weight: bold;">
                DESCRICAO BREVE DO PRATO (Resumo curto) *
            </label>
            <textarea name="descricao" rows="3" required placeholder="Ex: Tofu fermentado com aroma intenso e casca crocante..."
                style="width: 100%; background: #000; color: #fff; border: 1px solid #333; padding: 0.8rem; font-family: monospace; font-size: 0.95rem; line-height: 1.4;"></textarea>
            <span style="color: #666; font-size: 0.75rem; font-family: monospace; display: block; margin-top: 0.3rem;">
                Sera exibido como resumo nos cards da pagina inicial.
            </span>
        </div>

        <div style="margin-bottom: 1.5rem;">
            <label style="color: #3498db; display: block; margin-bottom: 0.4rem; font-family: monospace; font-weight: bold;">
                MODO DE PREPARO (Passo a Passo) *
            </label>
            <textarea name="modo_preparo" rows="6" required placeholder="1. Misture os ingredientes...&#10;2. Deixe fermentar...&#10;3. Frite em fogo alto..."
                style="width: 100%; background: #000; color: #fff; border: 1px solid #333; padding: 0.8rem; font-family: monospace; font-size: 0.95rem; line-height: 1.5;"></textarea>
            <span style="color: #666; font-size: 0.75rem; font-family: monospace; display: block; margin-top: 0.3rem;">
                Instrucoes detalhadas exibidas apenas na leitura do protocolo completo.
            </span>
        </div>

        <div style="margin-bottom: 1.5rem;">
            <label style="color: #2ecc71; display: block; margin-bottom: 0.5rem; font-family: monospace; font-weight: bold;">
                URL DA IMAGEM DO EXPERIMENTO (Opcional)
            </label>
            <input type="url" name="imagem" placeholder="Cole o link da foto aqui..."
                style="width: 100%; background: #000; color: #aaa; border: 1px solid #333; padding: 0.8rem; font-family: monospace; font-size: 0.95rem;">
        </div>

        <div style="margin-bottom: 1.5rem;">
            <label style="color: #3498db; display: block; margin-bottom: 0.5rem; font-family: monospace; font-weight: bold;">
                LINK EXTERNO / FONTE DE REFERÊNCIA *
            </label>
            <input type="text" name="link_externo" required placeholder="https://pt.wikipedia.org/... (Obrigatório pelo edital)"
                style="width: 100%; background: #000; color: #3498db; border: 1px solid #333; padding: 0.8rem; font-family: monospace; font-size: 0.95rem;">
            <span style="color: #666; font-size: 0.75rem; font-family: monospace; display: block; margin-top: 0.3rem;">
                Dica: Insira a URL contendo a documentação histórica ou vídeo demonstrativo da receita.
            </span>
        </div>

        <hr style="border-color: #222; margin: 2rem 0;">

        <div style="margin-bottom: 2rem;">
            <label style="color: #9b59b6; display: block; margin-bottom: 0.5rem; font-weight: bold; font-family: monospace;">
                [ SELECIONAR CATEGORIAS N:N ]
            </label>
            <p style="font-size: 0.8rem; color: #777; margin-bottom: 1rem; font-family: monospace;">
                Associe esta gororoba a uma ou mais opções previamente cadastradas:
            </p>

            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 0.6rem;">
                {{#each categorias}}
                <label style="background: #111; padding: 0.6rem; border: 1px solid #222; display: flex; align-items: center; gap: 0.5rem; cursor: pointer;">
                    <input type="checkbox" name="categorias" value="{{this.id}}">
                    <span style="color: #fff; font-family: monospace; font-size: 0.85rem;">{{this.nome}}</span>
                </label>
                {{/each}}
            </div>
        </div>

        <div style="margin-bottom: 2.5rem;">
            <label style="color: #e74c3c; display: block; margin-bottom: 0.5rem; font-weight: bold; font-family: monospace;">
                [ ADICIONAR COAUTORES RESPONSÁVEIS N:N ]
            </label>
            <p style="font-size: 0.8rem; color: #777; margin-bottom: 1rem; font-family: monospace;">
                Selecione os operadores que auxiliaram no preparo (sua autoria já está assegurada pelo sistema):
            </p>

            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 0.6rem; max-height: 160px; overflow-y: auto; padding-right: 0.4rem;">
                {{#each alunos}}
                <label style="background: #111; padding: 0.6rem; border: 1px solid #222; display: flex; align-items: center; gap: 0.5rem; cursor: pointer;">
                    <input type="checkbox" name="responsaveis" value="{{this.id}}">
                    <span style="color: #ccc; font-family: monospace; font-size: 0.85rem;">{{this.nome}}</span>
                </label>
                {{/each}}
            </div>
        </div>

        <button type="submit" style="background: #2ecc71; color: #000; border: none; width: 100%; padding: 1rem; font-family: monospace; font-weight: bold; font-size: 1.1rem; cursor: pointer;">
            [ PERSISTIR RECEITA NO SQLITE ]
        </button>
    </form>
</div>